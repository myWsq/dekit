{
  "name": "dekit-cli",
  "version": "0.1.1",
  "type": "module",
  "description": "A code-first design toolkit — preview, inspect, and debug your HTML/CSS designs in the browser",
  "keywords": ["design", "devtools", "inspector", "preview", "css", "html", "cli"],
  "license": "Apache-2.0",
  "repository": { "type": "git", "url": "https://github.com/myWsq/dekit" },
  "homepage": "https://github.com/myWsq/dekit",
  "bugs": { "url": "https://github.com/myWsq/dekit/issues" },
  "files": ["bin/", "src/", "editor/", "dist/", "templates/", "docs/usage.md"],
  "engines": { "node": ">=18" },
  "bin": {
    "dekit": "./bin/dekit.ts"
  },
  "scripts": {
    "dev": "tsx bin/dekit.ts",
    "build:editor": "vite build --config editor/vite.config.ts",
    "test": "vitest run",
    "prepublishOnly": "npm run build:editor"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "open": "^10.1.0",
    "overlayscrollbars": "^2.14.0",
    "overlayscrollbars-react": "^0.5.6",
    "react-icons": "^5.6.0",
    "sirv": "^3.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@vitejs/plugin-react": "^4.3.0"
  }
}
